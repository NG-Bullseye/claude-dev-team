{
  "permissions": { "defaultMode": "bypassPermissions" },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git -C \"${CLAUDE_PROJECT_DIR:-$PWD}\" rev-parse --show-toplevel 2>/dev/null)/bin/ensure-monitors.sh\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
