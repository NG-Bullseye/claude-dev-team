# =============================================================================
# Agent Pair Template — Konfiguration
# Kopiere diese Datei als .env und befülle sie mit deinen Werten.
# ALLE pfadabhängigen und namensabhängigen Einstellungen leben hier —
# keine hardcodierten Slugs in bin/, CLAUDE.md oder settings.json.
# =============================================================================

# --- PO-Agent (Domain Specialist, Mesh-Entry-Point) ---
PO_AGENT_NAME=my-po-agent          # Slug: tmux-Session-Name + Repo-Dir-Ref + Cache-Pfade
PO_AGENT_MODEL=sonnet              # Modell: sonnet | opus | haiku
PO_AGENT_ROLE="Dein Domain-Spezialist und Mesh-Ansprechpartner"

# --- Coding-Agent (Nested Implementierer, subordiniert zum PO) ---
CODING_AGENT_NAME=coding-agent     # Fast immer "coding-agent"; lebt als Subdir im PO-Repo
CODING_AGENT_MODEL=sonnet

# --- agent-mesh Integration (github.com/NG-Bullseye/agent-mesh) ---
# Wenn MESH_ENABLED=true: agent-mesh CLI + MCP wird als Kommunikations-Layer genutzt.
# Voraussetzung: agent-mesh installiert (pip install -e ~/repos/agent-mesh) + Redis läuft.
# Bei false: standalone-Betrieb, kein Redis nötig.
MESH_ENABLED=false
MESH_REDIS_URL=redis://localhost:6379/0   # Redis-URL (muss mit agent-mesh docker-compose übereinstimmen)
MESH_PREFIX=mesh                          # Stream-Key-Prefix (default: mesh)

# --- Domain-Dokumentation ---
DOMAIN_DOCS_PATH=./docs            # Verzeichnis mit allen domänenspezifischen Docs für den PO

# --- Repo-Pfade (normalerweise nicht ändern) ---
PO_AGENT_REPO="$HOME/repos/$PO_AGENT_NAME"
CODING_AGENT_REPO="$HOME/repos/$PO_AGENT_NAME/$CODING_AGENT_NAME"

# --- System-Kommandos (Symlinks via install.sh) ---
PO_AGENT_CMD="$HOME/.local/bin/$PO_AGENT_NAME"
CODING_AGENT_CMD="$HOME/.local/bin/$CODING_AGENT_NAME"
