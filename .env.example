# =============================================================================
# claude-dev-team — Configuration
# Copy this file as .env and fill in your values.
# All slug- and path-dependent settings live here —
# no hardcoded names anywhere in bin/, CLAUDE.md, or settings.json.
# =============================================================================

# --- Team identity ---
TEAM_NAME=my-team              # slug used everywhere: tmux sessions, cache paths, symlinks
                               # → sessions: <TEAM_NAME>-po  and  <TEAM_NAME>-developer

# --- Models (Claude Code subscription — no API key required) ---
PO_MODEL=sonnet                # sonnet | opus | haiku
DEVELOPER_MODEL=sonnet

# --- PO role description (used in CLAUDE.md and mesh registry) ---
PO_ROLE="Product Owner — domain specialist and team entry point"

# --- Domain documentation ---
DOMAIN_DOCS_PATH=./docs        # directory with all domain-specific docs for the PO

# --- agent-mesh integration (github.com/NG-Bullseye/agent-mesh) ---
# When MESH_ENABLED=true: PO registers in the mesh and receives messages via Redis Streams.
# Requires: pip install -e ~/repos/agent-mesh  +  docker-compose up -d (Redis)
# When false: standalone, no Redis needed.
MESH_ENABLED=false
MESH_REDIS_URL=redis://localhost:6379/0
MESH_PREFIX=mesh
