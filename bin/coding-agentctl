#!/bin/bash
# coding-agentctl — Launcher für den nested Coding-Agent (Implementierer, subordiniert zum PO)
# Lädt Konfiguration aus .env im Parent-Repo (PO-Repo-Root).
#
#   coding-agentctl            attach an laufende Session, sonst Cold-Start
#   coding-agentctl  -r        Frischer Neustart
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="$(dirname "$SCRIPT_DIR")"   # PO-Agent-Repo-Root

if [ ! -f "$REPO/.env" ]; then
  echo "FEHLER: $REPO/.env fehlt." >&2; exit 1
fi
# shellcheck source=/dev/null
source "$REPO/.env"

PO_NAME="${PO_AGENT_NAME:?PO_AGENT_NAME fehlt in .env}"
NAME="${CODING_AGENT_NAME:-coding-agent}"
MODEL="${CODING_AGENT_MODEL:-sonnet}"
CODING_REPO="$REPO/$NAME"         # nested: lebt als Subdir im PO-Repo
SID_FILE="$HOME/.cache/$PO_NAME-$NAME/launcher/$NAME.sid"
mkdir -p "$(dirname "$SID_FILE")"
[ -f "$SID_FILE" ] || uuidgen > "$SID_FILE"

MODEL_FLAG=""; [ -n "$MODEL" ] && MODEL_FLAG="--model $MODEL"

INIT_PROMPT="Frischer Neustart deiner nested Coding-Agent-Session. Lies deine CLAUDE.md, dann still bis der PO-Agent eine Aufgabe schickt — kein Begruessungs-Output."

start_fresh() {
  local sid; sid="$(uuidgen)"; echo "$sid" > "$SID_FILE"
  tmux new-session -d -s "$PO_NAME-$NAME" -c "$CODING_REPO"
  tmux send-keys -t "$PO_NAME-$NAME" "claude $MODEL_FLAG --session-id $sid '$INIT_PROMPT'" Enter
}

case "${1:-}" in
  -r|restart|--restart)
    tmux kill-session -t "$PO_NAME-$NAME" 2>/dev/null || true
    start_fresh
    echo "✅ $PO_NAME-$NAME frisch neugestartet."
    exit 0 ;;
  "") : ;;
  *) echo "$NAME: unbekannte Aktion '${1}'" >&2; exit 1 ;;
esac

SID="$(cat "$SID_FILE")"
SESSION="$PO_NAME-$NAME"
if [ -n "${TMUX:-}" ]; then
  cd "$CODING_REPO" && exec bash -c "claude $MODEL_FLAG --resume $SID || claude $MODEL_FLAG --session-id $SID"
fi
if tmux has-session -t "$SESSION" 2>/dev/null; then
  exec tmux attach-session -t "$SESSION"
else
  tmux new-session -d -s "$SESSION" -c "$CODING_REPO"
  tmux send-keys -t "$SESSION" "claude $MODEL_FLAG --resume $SID || claude $MODEL_FLAG --session-id $SID" Enter
  exec tmux attach-session -t "$SESSION"
fi
